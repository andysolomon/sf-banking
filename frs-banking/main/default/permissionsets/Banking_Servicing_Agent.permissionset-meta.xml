<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Banking Servicing Agent</label>
    <description>Least-privilege servicing access (walking skeleton): read Bank_Account__c + run the balance controller. No balance edit.</description>
    <hasActivationRequired>false</hasActivationRequired>

    <objectPermissions>
        <object>Bank_Account__c</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <objectPermissions>
        <object>Integration_Log__c</object>
        <allowRead>true</allowRead>
        <allowCreate>true</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>

    <fieldPermissions>
        <field>Bank_Account__c.Core_Account_Id__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Bank_Account__c.Balance_Minor__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Bank_Account__c.Balance_As_Of__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Bank_Account__c.Type__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Bank_Account__c.Status__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Bank_Account__c.Customer__c</field>
        <readable>true</readable>
        <editable>false</editable>
    </fieldPermissions>

    <!-- Integration_Log__c fields are editable so CalloutService can insert a log in the agent's context (v0.1.0; Phase 6 moves logging to a system/Platform-Event path). -->
    <fieldPermissions>
        <field>Integration_Log__c.Correlation_Id__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Integration_Log__c.Direction__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Integration_Log__c.Status__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>Integration_Log__c.Endpoint_Alias__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>

    <classAccesses>
        <apexClass>BankAccountController</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>CalloutService</apexClass>
        <enabled>true</enabled>
    </classAccesses>
</PermissionSet>
